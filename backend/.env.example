# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Neon PostgreSQL ──────────────────────────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://username:password@ep-xxx-xxx.us-east-1.aws.neon.tech/shikshaverse?sslmode=require

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_min_64_chars
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── AWS S3 ───────────────────────────────────────────────────────────────────
# IAM user with S3 permissions only (least privilege)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
  S3_BUCKET_NAME=shiksha-verse-media
  S3_PRESIGNED_URL_EXPIRES=3600
  
  # ── AWS CloudFront (CDN) ─────────────────────────────────────────────────────
  # Optional: If set, media links will use CloudFront instead of direct S3.
  # Format: d12345abcdef.cloudfront.net (no https:// or trailing slash)
  CLOUDFRONT_DOMAIN=

# ── Email / OTP ──────────────────────────────────────────────────────────────
# Option A: AWS SES (recommended for production)
# SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=AKIAIOSFODNN7EXAMPLE
# SMTP_PASS=yourSMTPpassword
# Option B: Gmail (dev/testing only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@shikshaverse.com

# ── OTP ──────────────────────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── SMS / Phone OTP (Twilio) ──────────────────────────────────────────────────
# Optional: If absent, OTP is logged to server console (dev only)
SMS_PROVIDER_KEY=
SMS_FROM_NUMBER=+919876543210

# ── Google SSO ────────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Register your Android SHA-1 fingerprint under the OAuth client
GOOGLE_CLIENT_ID=

# ── AI Vault Summary ──────────────────────────────────────────────────────────
# Optional: If absent, /api/vault/ai-summary returns 503
# Supports OpenAI (gpt-4o-mini default) or Anthropic (claude-haiku)
AI_SUMMARY_API_KEY=
AI_SUMMARY_MODEL=gpt-4o-mini
